# --- prise_mini_pc_ikea_annuel_um ---
prise_mini_pc_ikea_annuel_um:
  source: sensor.prise_mini_pc_ikea_energy
  name: "Prise Mini PC IKEA Annuel UM"
  unique_id: prise_mini_pc_ikea_annuel_um
  cycle: yearly

# --- prise_mini_pc_ikea_mensuel_um ---
prise_mini_pc_ikea_mensuel_um:
  source: sensor.prise_mini_pc_ikea_energy
  name: "Prise Mini PC IKEA Mensuel UM"
  unique_id: prise_mini_pc_ikea_mensuel_um
  cycle: monthly

# --- prise_mini_pc_ikea_hebdomadaire_um ---
prise_mini_pc_ikea_hebdomadaire_um:
  source: sensor.prise_mini_pc_ikea_energy
  name: "Prise Mini PC IKEA Hebdomadaire UM"
  unique_id: prise_mini_pc_ikea_hebdomadaire_um
  cycle: weekly

# --- prise_mini_pc_ikea_quotidien_um ---
prise_mini_pc_ikea_quotidien_um:
  source: sensor.prise_mini_pc_ikea_energy
  name: "Prise Mini PC IKEA Quotidien UM"
  unique_id: prise_mini_pc_ikea_quotidien_um
  cycle: daily

